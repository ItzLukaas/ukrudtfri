# Database (lokal: kør `docker compose up -d` og brug denne URL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ukrudtfri?schema=public"

# Auth (NextAuth v5)
AUTH_SECRET="generer-en-lang-tilfaeldig-streng"
NEXTAUTH_SECRET="valgfri-fallback"

# App URL (til auth redirects)
NEXTAUTH_URL="http://localhost:3000"

# Offentlig site-URL (bruges bl.a. til iCal-feed-link i admin — skal matche produktion)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Analytics (Plausible). Sæt domænet for at aktivere scriptet.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
# Valgfrit: eget script-host (fx self-hosted plausible)
NEXT_PUBLIC_PLAUSIBLE_SRC="https://plausible.io/js/script.js"

# Hemmelig nøgle til abonnementskalender: GET /api/admin/calendar/ics?token=...
ADMIN_ICAL_TOKEN="generer-en-lang-tilfaeldig-streng"

# Email (valgfrit — uden nøgle logges bekræftelser kun i dev)
RESEND_API_KEY=""
EMAIL_FROM="Ukrudtfri <booking@ukrudtfri.dk>"

# Påmindelses-mail (ca. 2 t før besøg): kald /api/booking-reminders med Bearer.
# På Vercel: sæt CRON_SECRET i projektet — Cron kalder GET hvert 10. min (se vercel.json).
CRON_SECRET=""
REMINDER_CRON_SECRET=""

# OSM Nominatim (anbefalet — identificerer din app)
NOMINATIM_CONTACT_EMAIL="din@email.dk"

# Seed (kun til første oprettelse af admin)
BOOTSTRAP_ADMIN_EMAIL="admin@ukrudtfri.dk"
BOOTSTRAP_ADMIN_PASSWORD="SkiftMig123!"
